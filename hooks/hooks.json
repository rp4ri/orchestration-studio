{
  "description": "Orchestration Studio hooks — tag-push guard (annotated tag must point at the intended tip), leak guard (outgoing pushes scanned for secrets + infra identifiers incl. BARE public IPs), symlink guard (no node_modules / absolute-path symlinks in commits), and session-start orchestration context (lists live tmux/rmux worker sessions).",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/detect-orchestration.sh",
            "timeout": 10,
            "statusMessage": "Detecting live worker sessions..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/tag-push-guard.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/leak-guard.sh",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/symlink-guard.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
